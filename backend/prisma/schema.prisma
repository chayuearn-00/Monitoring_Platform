generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model locations {
  location_id     Int         @id @default(autoincrement())
  country_name    String      @db.VarChar(20) 
  province_name   String      @db.VarChar(20) 
  building_name   String      @db.VarChar(20) 
  details  details[]

  @@map("locations")
}

model details {
  detail_id   Int      @id @default(autoincrement())
  location_id Int
  floor_id    Int
  hardware_id Int

  // Relationships
  location    locations @relation(fields: [location_id], references: [location_id])
  floor       floors    @relation(fields: [floor_id], references: [floor_id])
  hardware    hardware @relation(fields: [hardware_id], references: [hardware_id])
  
  monitor_logs monitor_logs[]
}

model current_status {
  hardware_id Int            @id
  status      machine_status
  start_time  DateTime       @db.Timestamp(6)

  hardware    hardware       @relation(fields: [hardware_id], references: [hardware_id], onDelete: NoAction, onUpdate: NoAction)

  @@index([hardware_id], map: "idx_status_hardware")
}

model devices {
  device_id Int        @id @default(autoincrement())
  device_name    String     @db.VarChar(30) @unique

  hardware  hardware[]
}

model hardware {
  hardware_id    Int             @id @default(autoincrement())
  machine_id     Int
  device_id      Int

  devices        devices         @relation(fields: [device_id], references: [device_id], onDelete: NoAction, onUpdate: NoAction)
  machine       machines        @relation(fields: [machine_id], references: [machine_id], onDelete: NoAction, onUpdate: NoAction)
  
  detail   details[]

  current_status current_status?
}

model machines {
  machine_id Int        @id @default(autoincrement())
  machine_name    String     @db.VarChar(50) @unique
  hardware   hardware[]
}

model monitor_logs {
  log_id           Int            @id @default(autoincrement())
  detail_id      Int
  start_time       DateTime       @db.Timestamp(6)
  end_time         DateTime       @db.Timestamp(6)
  duration_seconds Int
  status           machine_status
  detail         details          @relation(fields: [detail_id], references: [detail_id], onDelete: NoAction, onUpdate: NoAction)

  @@index([start_time], map: "idx_logs_start_time")
}

model floors {
  floor_id  Int        @id @default(autoincrement())
  floor_name       String?    @db.VarChar(3) @unique
  zones     zones[]
  details   details[]
}

model zones {
  zone_id   Int        @id @default(autoincrement())
  zone_name      String     @db.VarChar(20) @unique
  is_active Boolean?   @default(true)
  floors    floors[]
}

enum machine_status {
  RUNNING
  IDLE
  DOWN
  MAINTENANCE
}
